# Trackbox environment configuration
# Copy to .env and fill in values. Only OPENAI_API_KEY is required.
# See docs/setup.md for full documentation.

# ---------------------------------------------------------------------------
# Core (required)
# ---------------------------------------------------------------------------

# OpenAI API key — required for AI extraction of new email formats.
# Without this, only emails matching existing stored parsers will be processed.
OPENAI_API_KEY=sk-...

# OpenAI model to use for extraction and parser generation.
# gpt-4o is recommended; gpt-4o-mini is cheaper with slightly lower accuracy.
OPENAI_MODEL=gpt-4o

# Path to the SQLite database file.
# In Docker, use a volume-mounted path to persist data across restarts.
DATABASE_PATH=trackbox.db

# ---------------------------------------------------------------------------
# Core (optional)
# ---------------------------------------------------------------------------

# Maximum number of POST /ingest requests per minute (per process).
# RATE_LIMIT_PER_MINUTE=30

# Injected by CI — do not set manually.
# TRACKBOX_VERSION=dev
# TRACKBOX_BUILD_TIME=unknown

# ---------------------------------------------------------------------------
# DHL API (optional — only needed if using the DHL Unified API scraper)
# ---------------------------------------------------------------------------

# DHL Shipment Tracking - Unified API key (developer.dhl.com, free tier: 250 calls/day).
# If not set, the DHL Web scraper is used automatically (no key needed).
# DHL_API_KEY=

# DHL API secret (reserved for future OAuth; not currently used).
# DHL_API_SECRET=

# ---------------------------------------------------------------------------
# IMAP (optional — enables direct mailbox polling every IMAP_INTERVAL seconds)
# Both IMAP_HOST and IMAP_USER must be set to enable polling.
# ---------------------------------------------------------------------------

# IMAP server hostname.
# IMAP_HOST=mail.example.com

# IMAP server port. Default 993 (SSL). Use 143 for STARTTLS.
# IMAP_PORT=993

# IMAP username (usually the full email address).
# IMAP_USER=notifications@example.com

# IMAP password or app-specific password.
# IMAP_PASSWORD=

# Set to false to disable SSL (e.g. for a local mail server on port 143).
# IMAP_SSL=true

# Mailbox folder to scan for new (UNSEEN) emails.
# IMAP_FOLDER=INBOX

# Folder where processed emails are moved after ingestion (created if missing).
# IMAP_DONE_FOLDER=Trackbox/Processed

# Poll interval in seconds (default: 300 = 5 minutes).
# IMAP_INTERVAL=300

# ---------------------------------------------------------------------------
# MQTT / Home Assistant (optional)
# Set MQTT_HOST to enable. Also enable MQTT in the Settings UI after starting.
# ---------------------------------------------------------------------------

# MQTT broker hostname. If not set, MQTT is disabled entirely.
# MQTT_HOST=homeassistant.local

# MQTT broker port.
# MQTT_PORT=1883

# MQTT username. Leave empty for brokers without authentication.
# MQTT_USER=

# MQTT password.
# MQTT_PASSWORD=

# Topic prefix for all published messages.
# Change this if you run multiple Trackbox instances on the same broker.
# MQTT_TOPIC_PREFIX=trackbox
